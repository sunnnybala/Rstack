#!/usr/bin/env bash
# rstack-telemetry-log — append a telemetry event to local JSONL
#
# Data flow:
#   preamble (start) ──▶ .pending marker
#   preamble (epilogue) ──▶ rstack-telemetry-log ──▶ skill-usage.jsonl
#                                                 └──▶ rstack-telemetry-sync (bg)
#
# Usage:
#   rstack-telemetry-log --skill experiment --duration 342 --outcome success \
#     --session-id "12345-1710756600" --compute-provider modal --gpu-type A100
#
# Env overrides (for testing):
#   RSTACK_STATE_DIR  — override ~/.rstack state directory
#   RSTACK_DIR        — override auto-detected rstack root
#
# NOTE: Uses set -uo pipefail (no -e) — telemetry must never exit non-zero
set -uo pipefail

RSTACK_DIR="${RSTACK_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${RSTACK_STATE_DIR:-$HOME/.rstack}"
ANALYTICS_DIR="$STATE_DIR/analytics"
JSONL_FILE="$ANALYTICS_DIR/skill-usage.jsonl"
PENDING_DIR="$ANALYTICS_DIR"  # .pending-* files live here
CONFIG_CMD="$RSTACK_DIR/bin/rstack-config"
VERSION_FILE="$RSTACK_DIR/VERSION"

# ─── Parse flags ─────────────────────────────────────────────
SKILL=""
DURATION=""
OUTCOME="unknown"
USED_BROWSE="false"
SESSION_ID=""
ERROR_CLASS=""
ERROR_MESSAGE=""
FAILED_STEP=""
EVENT_TYPE="skill_run"
SOURCE=""
COMPUTE_PROVIDER=""
GPU_TYPE=""
VENUE=""
PIPELINE_STAGE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --skill)             SKILL="$2"; shift 2 ;;
    --duration)          DURATION="$2"; shift 2 ;;
    --outcome)           OUTCOME="$2"; shift 2 ;;
    --used-browse)       USED_BROWSE="$2"; shift 2 ;;
    --session-id)        SESSION_ID="$2"; shift 2 ;;
    --error-class)       ERROR_CLASS="$2"; shift 2 ;;
    --error-message)     ERROR_MESSAGE="$2"; shift 2 ;;
    --failed-step)       FAILED_STEP="$2"; shift 2 ;;
    --event-type)        EVENT_TYPE="$2"; shift 2 ;;
    --source)            SOURCE="$2"; shift 2 ;;
    --compute-provider)  COMPUTE_PROVIDER="$2"; shift 2 ;;
    --gpu-type)          GPU_TYPE="$2"; shift 2 ;;
    --venue)             VENUE="$2"; shift 2 ;;
    --pipeline-stage)    PIPELINE_STAGE="$2"; shift 2 ;;
    *) shift ;;
  esac
done

# Source: flag > env > default 'live'
SOURCE="${SOURCE:-${RSTACK_TELEMETRY_SOURCE:-live}}"

# ─── Read telemetry tier ─────────────────────────────────────
TIER="$("$CONFIG_CMD" get telemetry 2>/dev/null || true)"
TIER="${TIER:-off}"

# Validate tier
case "$TIER" in
  off|anonymous|community) ;;
  *) TIER="off" ;;  # invalid value → default to off
esac

if [ "$TIER" = "off" ]; then
  # Still clear pending markers for this session even if telemetry is off
  [ -n "$SESSION_ID" ] && rm -f "$PENDING_DIR/.pending-$SESSION_ID" 2>/dev/null || true
  exit 0
fi

# ─── Finalize stale .pending markers ────────────────────────
for PFILE in "$PENDING_DIR"/.pending-*; do
  [ -f "$PFILE" ] || continue
  PFILE_BASE="$(basename "$PFILE")"
  PFILE_SID="${PFILE_BASE#.pending-}"
  [ "$PFILE_SID" = "$SESSION_ID" ] && continue

  PENDING_DATA="$(cat "$PFILE" 2>/dev/null || true)"
  rm -f "$PFILE" 2>/dev/null || true
  if [ -n "$PENDING_DATA" ]; then
    P_SKILL="$(echo "$PENDING_DATA" | grep -o '"skill":"[^"]*"' | head -1 | awk -F'"' '{print $4}')"
    P_TS="$(echo "$PENDING_DATA" | grep -o '"ts":"[^"]*"' | head -1 | awk -F'"' '{print $4}')"
    P_SID="$(echo "$PENDING_DATA" | grep -o '"session_id":"[^"]*"' | head -1 | awk -F'"' '{print $4}')"
    P_VER="$(echo "$PENDING_DATA" | grep -o '"rstack_version":"[^"]*"' | head -1 | awk -F'"' '{print $4}')"
    P_OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
    P_ARCH="$(uname -m)"

    mkdir -p "$ANALYTICS_DIR"
    printf '{"v":1,"ts":"%s","event_type":"skill_run","skill":"%s","session_id":"%s","rstack_version":"%s","os":"%s","arch":"%s","duration_s":null,"outcome":"unknown","error_class":null,"error_message":null,"failed_step":null,"used_browse":false,"sessions":1,"installation_id":null,"source":"live","compute_provider":null,"gpu_type":null,"venue":null,"pipeline_stage":null,"_repo_slug":"","_branch":""}\n' \
      "$P_TS" "$P_SKILL" "$P_SID" "$P_VER" "$P_OS" "$P_ARCH" >> "$JSONL_FILE" 2>/dev/null || true
  fi
done

# Clear our own session's pending marker
[ -n "$SESSION_ID" ] && rm -f "$PENDING_DIR/.pending-$SESSION_ID" 2>/dev/null || true

# ─── Collect metadata ────────────────────────────────────────
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%S 2>/dev/null || echo "")"
RSTACK_VERSION="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]' || echo "unknown")"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"
SESSIONS="1"
if [ -d "$STATE_DIR/sessions" ]; then
  _SC="$(find "$STATE_DIR/sessions" -mmin -120 -type f 2>/dev/null | wc -l | tr -d ' \n\r\t')"
  [ -n "$_SC" ] && [ "$_SC" -gt 0 ] 2>/dev/null && SESSIONS="$_SC"
fi

# Generate installation_id for community tier (consent-gated: only when tier=community)
INSTALL_ID=""
if [ "$TIER" = "community" ]; then
  ID_FILE="$STATE_DIR/installation-id"
  if [ -f "$ID_FILE" ]; then
    INSTALL_ID="$(cat "$ID_FILE" 2>/dev/null)"
  fi
  if [ -z "$INSTALL_ID" ]; then
    if command -v uuidgen >/dev/null 2>&1; then
      INSTALL_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    elif [ -r /proc/sys/kernel/random/uuid ]; then
      INSTALL_ID="$(cat /proc/sys/kernel/random/uuid)"
    else
      INSTALL_ID="$(od -An -tx1 -N16 /dev/urandom 2>/dev/null | tr -d ' \n')"
    fi
    if [ -n "$INSTALL_ID" ]; then
      mkdir -p "$(dirname "$ID_FILE")" 2>/dev/null
      printf '%s' "$INSTALL_ID" > "$ID_FILE" 2>/dev/null
    fi
  fi
fi

# Local-only fields (never sent remotely)
REPO_SLUG=""
BRANCH=""
if command -v git >/dev/null 2>&1; then
  REPO_SLUG="$(git remote get-url origin 2>/dev/null | sed 's|.*[:/]\([^/]*/[^/]*\)\.git$|\1|;s|.*[:/]\([^/]*/[^/]*\)$|\1|' | tr '/' '-' 2>/dev/null || true)"
  BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
fi

# ─── Construct and append JSON ───────────────────────────────
mkdir -p "$ANALYTICS_DIR"

# Sanitize string fields for JSON safety (strip quotes, backslashes, control chars)
json_safe() { printf '%s' "$1" | tr -d '"\\\n\r\t' | head -c 200; }

# Sanitize error messages: strip file paths, secrets, cap at 100 chars
sanitize_error_msg() {
  printf '%s' "$1" \
    | sed -E 's|/[^ ]*(/[^ ]*)+|[PATH]|g' \
    | sed -E 's/(Key|Token|Secret|Password|Authorization):[^ ]*/\1:[REDACTED]/gi' \
    | tr -d '"\\\n\r\t' \
    | head -c 100
}

SKILL="$(json_safe "$SKILL")"
OUTCOME="$(json_safe "$OUTCOME")"
SESSION_ID="$(json_safe "$SESSION_ID")"
SOURCE="$(json_safe "$SOURCE")"
EVENT_TYPE="$(json_safe "$EVENT_TYPE")"
REPO_SLUG="$(json_safe "$REPO_SLUG")"
BRANCH="$(json_safe "$BRANCH")"
COMPUTE_PROVIDER="$(json_safe "$COMPUTE_PROVIDER")"
GPU_TYPE="$(json_safe "$GPU_TYPE")"
VENUE="$(json_safe "$VENUE")"
PIPELINE_STAGE="$(json_safe "$PIPELINE_STAGE")"

# Nullable string fields
ERR_FIELD="null"
[ -n "$ERROR_CLASS" ] && ERR_FIELD="\"$(json_safe "$ERROR_CLASS")\""

ERR_MSG_FIELD="null"
[ -n "$ERROR_MESSAGE" ] && ERR_MSG_FIELD="\"$(sanitize_error_msg "$ERROR_MESSAGE")\""

STEP_FIELD="null"
[ -n "$FAILED_STEP" ] && STEP_FIELD="\"$(json_safe "$FAILED_STEP")\""

# Cap unreasonable durations
if [ -n "$DURATION" ] && [ "$DURATION" -gt 86400 ] 2>/dev/null; then
  DURATION=""  # null if > 24h
fi
if [ -n "$DURATION" ] && [ "$DURATION" -lt 0 ] 2>/dev/null; then
  DURATION=""  # null if negative
fi

DUR_FIELD="null"
[ -n "$DURATION" ] && DUR_FIELD="$DURATION"

INSTALL_FIELD="null"
[ -n "$INSTALL_ID" ] && INSTALL_FIELD="\"$INSTALL_ID\""

BROWSE_BOOL="false"
[ "$USED_BROWSE" = "true" ] && BROWSE_BOOL="true"

# Research-specific nullable fields
COMPUTE_FIELD="null"
[ -n "$COMPUTE_PROVIDER" ] && COMPUTE_FIELD="\"$COMPUTE_PROVIDER\""

GPU_FIELD="null"
[ -n "$GPU_TYPE" ] && GPU_FIELD="\"$GPU_TYPE\""

VENUE_FIELD="null"
[ -n "$VENUE" ] && VENUE_FIELD="\"$VENUE\""

STAGE_FIELD="null"
[ -n "$PIPELINE_STAGE" ] && STAGE_FIELD="\"$PIPELINE_STAGE\""

printf '{"v":1,"ts":"%s","event_type":"%s","skill":"%s","session_id":"%s","rstack_version":"%s","os":"%s","arch":"%s","duration_s":%s,"outcome":"%s","error_class":%s,"error_message":%s,"failed_step":%s,"used_browse":%s,"sessions":%s,"installation_id":%s,"source":"%s","compute_provider":%s,"gpu_type":%s,"venue":%s,"pipeline_stage":%s,"_repo_slug":"%s","_branch":"%s"}\n' \
  "$TS" "$EVENT_TYPE" "$SKILL" "$SESSION_ID" "$RSTACK_VERSION" "$OS" "$ARCH" \
  "$DUR_FIELD" "$OUTCOME" "$ERR_FIELD" "$ERR_MSG_FIELD" "$STEP_FIELD" \
  "$BROWSE_BOOL" "${SESSIONS:-1}" \
  "$INSTALL_FIELD" "$SOURCE" \
  "$COMPUTE_FIELD" "$GPU_FIELD" "$VENUE_FIELD" "$STAGE_FIELD" \
  "$REPO_SLUG" "$BRANCH" >> "$JSONL_FILE" 2>/dev/null || true

# ─── Trigger sync if tier is not off ─────────────────────────
SYNC_CMD="$RSTACK_DIR/bin/rstack-telemetry-sync"
if [ -x "$SYNC_CMD" ]; then
  "$SYNC_CMD" 2>/dev/null &
fi

exit 0
