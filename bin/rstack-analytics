#!/usr/bin/env bash
# rstack-analytics — personal usage dashboard from local JSONL
#
# Usage:
#   rstack-analytics          # default: last 7 days
#   rstack-analytics 7d       # last 7 days
#   rstack-analytics 30d      # last 30 days
#   rstack-analytics all      # all time
#
# Env overrides (for testing):
#   RSTACK_STATE_DIR  — override ~/.rstack state directory
set -uo pipefail

STATE_DIR="${RSTACK_STATE_DIR:-$HOME/.rstack}"
JSONL_FILE="$STATE_DIR/analytics/skill-usage.jsonl"

# ─── Parse time window ───────────────────────────────────────
WINDOW="${1:-7d}"
case "$WINDOW" in
  7d)  DAYS=7;  LABEL="last 7 days" ;;
  30d) DAYS=30; LABEL="last 30 days" ;;
  all) DAYS=0;  LABEL="all time" ;;
  *)   DAYS=7;  LABEL="last 7 days" ;;
esac

# ─── Check for data ──────────────────────────────────────────
if [ ! -f "$JSONL_FILE" ]; then
  echo "rstack usage — no data yet"
  echo ""
  echo "Usage data will appear here after you use rstack skills"
  echo "with telemetry enabled (rstack-config set telemetry anonymous)."
  exit 0
fi

TOTAL_LINES="$(wc -l < "$JSONL_FILE" | tr -d ' ')"
if [ "$TOTAL_LINES" = "0" ]; then
  echo "rstack usage — no data yet"
  exit 0
fi

# ─── Filter by time window ───────────────────────────────────
if [ "$DAYS" -gt 0 ] 2>/dev/null; then
  if date -v-1d +%Y-%m-%d >/dev/null 2>&1; then
    CUTOFF="$(date -v-${DAYS}d -u +%Y-%m-%dT%H:%M:%SZ)"
  else
    CUTOFF="$(date -u -d "$DAYS days ago" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "2000-01-01T00:00:00Z")"
  fi
  # Filter: skill_run events (new format) OR basic skill events (old format, no event_type)
  FILTERED="$(awk -F'"' -v cutoff="$CUTOFF" '
    /"ts":"/ {
      if (/"event":"hook_fire"/) next
      if (/"event_type":"/ && !/"event_type":"skill_run"/) next
      for (i=1; i<=NF; i++) {
        if ($i == "ts" && $(i+1) ~ /^:/) {
          ts = $(i+2)
          if (ts >= cutoff) { print; break }
        }
      }
    }
  ' "$JSONL_FILE")"
else
  FILTERED="$(awk '/"ts":"/ && !/"event":"hook_fire"/' "$JSONL_FILE" | grep -v '"event_type":"upgrade_' 2>/dev/null || true)"
fi

if [ -z "$FILTERED" ]; then
  echo "rstack usage ($LABEL) — no skill runs found"
  exit 0
fi

# ─── Aggregate by skill ──────────────────────────────────────
SKILL_COUNTS="$(echo "$FILTERED" | awk -F'"' '
  /"skill":"/ {
    for (i=1; i<=NF; i++) {
      if ($i == "skill" && $(i+1) ~ /^:/) {
        skill = $(i+2)
        counts[skill]++
        break
      }
    }
  }
  END {
    for (s in counts) print counts[s], s
  }
' | sort -rn)"

# Count outcomes
TOTAL="$(echo "$FILTERED" | wc -l | tr -d ' ')"
SUCCESS="$(echo "$FILTERED" | grep -c '"outcome":"success"' || true)"
SUCCESS="${SUCCESS:-0}"; SUCCESS="$(echo "$SUCCESS" | tr -d ' \n\r\t')"
ERRORS="$(echo "$FILTERED" | grep -c '"outcome":"error"' || true)"
ERRORS="${ERRORS:-0}"; ERRORS="$(echo "$ERRORS" | tr -d ' \n\r\t')"
# Old format events have no outcome field — count them as successful
NO_OUTCOME="$(echo "$FILTERED" | grep -vc '"outcome":' || true)"
NO_OUTCOME="${NO_OUTCOME:-0}"; NO_OUTCOME="$(echo "$NO_OUTCOME" | tr -d ' \n\r\t')"
SUCCESS=$(( SUCCESS + NO_OUTCOME ))

if [ "$TOTAL" -gt 0 ] 2>/dev/null; then
  SUCCESS_RATE=$(( SUCCESS * 100 / TOTAL ))
else
  SUCCESS_RATE=100
fi

# ─── Calculate total duration ────────────────────────────────
TOTAL_DURATION="$(echo "$FILTERED" | awk -F'[:,]' '
  /"duration_s"/ {
    for (i=1; i<=NF; i++) {
      if ($i ~ /"duration_s"/) {
        val = $(i+1)
        gsub(/[^0-9.]/, "", val)
        if (val+0 > 0) total += val
      }
    }
  }
  END { printf "%.0f", total }
')"

TOTAL_DURATION="${TOTAL_DURATION:-0}"
if [ "$TOTAL_DURATION" -ge 3600 ] 2>/dev/null; then
  HOURS=$(( TOTAL_DURATION / 3600 ))
  MINS=$(( (TOTAL_DURATION % 3600) / 60 ))
  DUR_DISPLAY="${HOURS}h ${MINS}m"
elif [ "$TOTAL_DURATION" -ge 60 ] 2>/dev/null; then
  MINS=$(( TOTAL_DURATION / 60 ))
  DUR_DISPLAY="${MINS}m"
else
  DUR_DISPLAY="${TOTAL_DURATION}s"
fi

# ─── Render output ───────────────────────────────────────────
echo "rstack usage ($LABEL)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

MAX_COUNT="$(echo "$SKILL_COUNTS" | head -1 | awk '{print $1}')"
BAR_WIDTH=20

echo "$SKILL_COUNTS" | while read -r COUNT SKILL; do
  if [ "$MAX_COUNT" -gt 0 ] 2>/dev/null; then
    BAR_LEN=$(( COUNT * BAR_WIDTH / MAX_COUNT ))
  else
    BAR_LEN=1
  fi
  [ "$BAR_LEN" -lt 1 ] && BAR_LEN=1

  BAR=""
  i=0
  while [ "$i" -lt "$BAR_LEN" ]; do
    BAR="${BAR}█"
    i=$(( i + 1 ))
  done

  AVG_DUR="$(echo "$FILTERED" | awk -v skill="$SKILL" '
    index($0, "\"skill\":\"" skill "\"") > 0 {
      n = split($0, parts, "\"duration_s\":")
      if (n >= 2) {
        gsub(/[^0-9.].*/, "", parts[2])
        if (parts[2]+0 > 0) { total += parts[2]; count++ }
      }
    }
    END { if (count > 0) printf "%.0f", total/count; else print "0" }
  ')"

  if [ "$AVG_DUR" -ge 60 ] 2>/dev/null; then
    AVG_DISPLAY="$(( AVG_DUR / 60 ))m"
  else
    AVG_DISPLAY="${AVG_DUR}s"
  fi

  printf "  /%-20s %s  %d runs  (avg %s)\n" "$SKILL" "$BAR" "$COUNT" "$AVG_DISPLAY"
done

echo ""
echo "Success rate: ${SUCCESS_RATE}% | Errors: ${ERRORS} | Total time: ${DUR_DISPLAY}"
echo "Events: ${TOTAL} skill runs"

# ─── Research-specific stats ─────────────────────────────────
MODAL_COUNT="$(echo "$FILTERED" | grep -c '"compute_provider":"modal"' || true)"
LOCAL_COUNT="$(echo "$FILTERED" | grep -c '"compute_provider":"local"' || true)"
MODAL_COUNT="$(echo "$MODAL_COUNT" | tr -d ' \n\r\t')"
LOCAL_COUNT="$(echo "$LOCAL_COUNT" | tr -d ' \n\r\t')"

PIPELINE_COUNT="$(echo "$FILTERED" | grep -c '"pipeline_stage":"research"' || true)"
PIPELINE_COUNT="$(echo "$PIPELINE_COUNT" | tr -d ' \n\r\t')"

# Venue breakdown
VENUE_STATS="$(echo "$FILTERED" | awk -F'"' '
  /"venue":"/ {
    for (i=1; i<=NF; i++) {
      if ($i == "venue" && $(i+1) ~ /^:/) {
        v = $(i+2)
        if (v != "" && v != "null") venues[v]++
        break
      }
    }
  }
  END {
    first = 1
    for (v in venues) {
      if (!first) printf " | "
      printf "%s %d", v, venues[v]
      first = 0
    }
  }
')"

# Only show research section if there's research data
if [ "${MODAL_COUNT:-0}" -gt 0 ] || [ "${LOCAL_COUNT:-0}" -gt 0 ] || [ "${PIPELINE_COUNT:-0}" -gt 0 ] || [ -n "$VENUE_STATS" ]; then
  echo ""
  RESEARCH_LINE="Research:"
  if [ "${MODAL_COUNT:-0}" -gt 0 ] || [ "${LOCAL_COUNT:-0}" -gt 0 ]; then
    RESEARCH_LINE="$RESEARCH_LINE modal ${MODAL_COUNT:-0} | local ${LOCAL_COUNT:-0}"
  fi
  if [ "${PIPELINE_COUNT:-0}" -gt 0 ]; then
    RESEARCH_LINE="$RESEARCH_LINE | Full pipelines: ${PIPELINE_COUNT}"
  fi
  echo "$RESEARCH_LINE"
  if [ -n "$VENUE_STATS" ]; then
    echo "Venues: $VENUE_STATS"
  fi
fi
